## 💎 Итог: полный код с `params`
```python
import requests

class TestCreateRandomJokeCategory():  # заодно поправили опечатку
    """Класс для отправки запросов на получение шуток по категориям"""

    url = 'https://api.chucknorris.io/jokes/random'

    def test_create_random_joke_category_positive(self, category, expected_status_code):
        """Позитивный тест: проверка статус-кода и соответствия категории"""

        # 🧙‍♂️ params творит волшебство
        result = requests.get(self.url, params={'category': category})
        print(f'Отправлен запрос: {result.url}')

        # Проверка статус-кода
        assert result.status_code == expected_status_code, \
            f'ОЖИДАЛСЯ статус-код {expected_status_code}, но получен {result.status_code}'
        print(f'✅ Статус-код {result.status_code} корректен')

        # Извлекаем данные
        data = result.json()
        joke_text = data.get("value")
        categories = data.get("categories")
        print(f'Шутка: {joke_text}')
        print(f'Категории: {categories}')

        # Проверяем категорию
        assert len(categories) > 0, 'Список категорий пуст'
        assert categories[0] == category, \
            f'ОЖИДАЛАСЬ категория "{category}", но получена "{categories[0]}"'
        print('✅ Категория корректна')

        print("🎉 Тест прошел успешно!\n")

# Запуск
start_test = TestCreateRandomJokeCategory()
start_test.test_create_random_joke_category_positive('animal', 200)
```

