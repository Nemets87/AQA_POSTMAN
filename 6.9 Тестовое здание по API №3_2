## 🧙‍♂️ Учитель: Полный код с задержкой 1 секунда и диагностикой

Ты прав, давай **увеличим задержку до 1 секунды** и добавим вывод полного JSON-ответа при ошибке — чтобы мы точно увидели, что возвращает API.

Ниже – **весь код целиком**, который ты можешь скопировать и запустить.

```python
import requests
import time
from typing import Dict, Any, List

# ====================== КЛАСС API (твой, немного доработанный) ======================
class LocationAPI:
    """📘 API-библиотека для работы с локациями"""
    def __init__(self, base_url: str, key: str) -> None:
        self.base_url = base_url.rstrip('/')
        self.key = key

    def _build_url(self, resource: str, extra_params: str = "") -> str:
        url = f"{self.base_url}{resource}{self.key}"
        if extra_params:
            url += extra_params
        return url

    def _send_request(self, method: str, url: str, json_data: Dict[str, Any] = None) -> Dict[str, Any]:
        print(f"📨 {method.upper()} → {url}")
        if method.lower() == 'post':
            response = requests.post(url, json=json_data)
        elif method.lower() == 'get':
            response = requests.get(url)
        else:
            raise ValueError(f"Метод {method} не поддерживается")
        
        # Проверяем HTTP статус
        assert response.status_code == 200, f"❌ HTTP {response.status_code}"
        print(f"✅ HTTP 200 OK")
        return response.json()

    def create_location(self, location_data: Dict[str, Any]) -> Dict[str, Any]:
        post_resource = '/maps/api/place/add/json'
        url = self._build_url(post_resource)
        response_json = self._send_request('post', url, json_data=location_data)
        # Проверка бизнес-логики
        assert response_json.get('status') == 'OK', f"❌ Ошибка POST: {response_json}"
        assert 'place_id' in response_json, "❌ Нет place_id"
        print(f"📍 Создан place_id: {response_json['place_id']}")
        return response_json

    def get_location(self, place_id: str) -> Dict[str, Any]:
        get_resource = '/maps/api/place/get/json'
        extra = f"&place_id={place_id}"
        url = self._build_url(get_resource, extra)
        response_json = self._send_request('get', url)
        
        # 🔍 Диагностика: показываем полный ответ, если статус не OK
        if response_json.get('status') != 'OK':
            print(f"⚠️ GET вернул: {response_json}")
        assert response_json.get('status') == 'OK', f"❌ place_id {place_id} не найден: {response_json}"
        print(f"🔍 Место {place_id} существует")
        return response_json


# ====================== ГЕНЕРАТОР УНИКАЛЬНЫХ ЛОКАЦИЙ ======================
def generate_location_variant(index: int) -> Dict[str, Any]:
    """Создаёт уникальную локацию для каждого вызова (меняем имя, адрес, координаты)"""
    return {
        "location": {
            "lat": -38.383494 + index * 0.001,
            "lng": 33.427362 + index * 0.001
        },
        "accuracy": 50,
        "name": f"Frontline house #{index}",
        "phone_number": "(+91) 983 893 3937",
        "address": f"29, side layout, cohen {index:02d}",
        "types": ["shoe park", "shop"],
        "website": "http://google.com",
        "language": "French-IN"
    }


# ====================== ОСНОВНАЯ ПРОГРАММА ======================
if __name__ == "__main__":
    print("\n🌟 ЗАДАНИЕ: 5 локаций → файл → проверка GET 🌟")
    print("=" * 60)

    # Создаём клиента
    api = LocationAPI(
        base_url='https://rahulshettyacademy.com',
        key='?key=qaclick123'
    )

    # ШАГ 1: POST 5 локаций с задержкой 1 секунда между ними
    place_ids = []
    print("\n🏗️ Шаг 1: Создаём 5 локаций (POST)")
    for i in range(1, 6):
        print(f"\n--- POST #{i} ---")
        location_data = generate_location_variant(i)
        response = api.create_location(location_data)
        place_ids.append(response['place_id'])
        print(f"⏳ Ждём 1 секунду перед следующим POST...")
        time.sleep(1)   # задержка 1 секунда

    # ШАГ 2: Сохраняем place_id в файл
    filename = "place_ids.txt"
    with open(filename, "w", encoding="utf-8") as f:
        for pid in place_ids:
            f.write(pid + "\n")
    print(f"\n💾 Файл '{filename}' сохранён ({len(place_ids)} записей)")

    # ШАГ 3: Читаем из файла (не используем старый список place_ids)
    print(f"\n📂 Шаг 2: Читаем из файла '{filename}'")
    ids_from_file = []
    with open(filename, "r", encoding="utf-8") as f:
        for line in f:
            clean = line.strip()
            if clean:
                ids_from_file.append(clean)
    print(f"Прочитано {len(ids_from_file)} ID: {ids_from_file}")

    # ШАГ 4: GET-проверка каждого place_id с задержкой 1 секунда
    print("\n🔍 Шаг 3: Проверяем каждый place_id через GET")
    all_ok = True
    for idx, pid in enumerate(ids_from_file, start=1):
        print(f"\n--- GET #{idx} (place_id: {pid[:20]}...) ---")
        try:
            api.get_location(pid)
            print(f"✅ Место #{idx} существует")
        except AssertionError as e:
            print(f"❌ {e}")
            all_ok = False
        print(f"⏳ Ждём 1 секунду перед следующим GET...")
        time.sleep(1)

    # ИТОГ
    print("\n" + "=" * 60)
    if all_ok and len(ids_from_file) == 5:
        print("🎉 ВСЕ 5 PLACE_ID ИЗ ФАЙЛА СУЩЕСТВУЮТ! ЗАДАНИЕ ВЫПОЛНЕНО.")
    else:
        print("⚠️ Что-то пошло не так. Возможно, API временно блокирует частые запросы.")
        print("💡 Попробуй увеличить задержку до 2-3 секунд.")
```

