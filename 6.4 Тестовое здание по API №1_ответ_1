Теперь у нас в переменной `categories` лежит список – 16 элементов. Именно по ним мы пойдём в цикле.

---

### 🧙 Два способа добыть шутку по категории

**Способ 1 – params (словарь аргументов)**  
Requests сам превращает словарь `{'category': 'animal'}` в `?category=animal` – удобно, меньше шансов ошибиться в знаках вопроса и амперсандах.

**Способ 2 – ручная строка**  
Мы берём базовый URL и добавляем `'?category=' + category`. Тоже работает, главное не забыть `?`.

---

### 🏗️ Пишем общий класс-сборщик шуток (с комментариями и проверками)

```python
import requests
from typing import List, Dict

class ChuckNorrisJokeCollector:
    """
    Наш школьный проект: собрать по одной шутке на каждую категорию.
    Используем два разрешённых подхода к формированию запроса.
    """

    def __init__(self):
        self.base_random_url = 'https://api.chucknorris.io/jokes/random'
        self.categories: List[str] = []   # здесь будем хранить все категории

    def fetch_categories(self) -> List[str]:
        """Получить список всех категорий с сервера."""
        url = 'https://api.chucknorris.io/jokes/categories'
        print(f'📡 Запрашиваем категории: {url}')
        resp = requests.get(url)
        print(f'📬 Статус ответа: {resp.status_code}')
        # Проверка – как замок на двери, без него дальше не идём
        assert resp.status_code == 200, f'Ошибка запроса категорий! Код {resp.status_code}'
        categories = resp.json()
        print(f'✅ Получено категорий: {len(categories)}')
        self.categories = categories
        return categories

    def get_joke_by_category_params(self, category: str) -> Dict[str, Any]:
        """
        Способ №1 – передача параметров через params.
        Возвращает полный ответ JSON (словарь с ключами value, categories и др.)
        """
        print(f'🥋 [params] Запрашиваю шутку для категории: {category}')
        # requests сама подставит ?category=... , никакой магии строк
        resp = requests.get(self.base_random_url, params={'category': category})
        print(f'    Статус: {resp.status_code}', end='')
        if resp.status_code == 200:
            print(' ✔️')
        else:
            print(f' ❌ (что-то пошло не так)')
        return resp.json()

    def get_joke_by_category_string(self, category: str) -> Dict[str, Any]:
        """
        Способ №2 – собираем URL вручную при помощи f-строки.
        """
        url = f'{self.base_random_url}?category={category}'
        print(f'🧵 [string] Запрашиваю шутку для категории: {category}')
        print(f'    Полный URL: {url}')
        resp = requests.get(url)
        print(f'    Статус: {resp.status_code}', end='')
        if resp.status_code == 200:
            print(' ✔️')
        else:
            print(f' ❌ (код {resp.status_code})')
        return resp.json()

    def collect_all_jokes(self, method: str = 'params') -> List[Dict[str, Any]]:
        """
        Главный метод – проходит по всем категориям и собирает шутки.
        method: 'params' или 'string' – выбираем способ запроса.
        Возвращает список словарей (каждый – полный ответ сервера).
        """
        if not self.categories:
            print('⚠️ Категории ещё не загружены. Сначала вызови fetch_categories()')
            return []

        jokes = []
        # Цикл – заменяет 16 одинаковых строк! Минимум кода, максимум пользы.
        for idx, cat in enumerate(self.categories, start=1):
            print(f'\n--- Обрабатываю категорию {idx}/{len(self.categories)}: {cat} ---')
            if method == 'params':
                joke_data = self.get_joke_by_category_params(cat)
            elif method == 'string':
                joke_data = self.get_joke_by_category_string(cat)
            else:
                raise ValueError("Метод должен быть 'params' или 'string'")

            # Дополнительная проверка – на всякий случай убедимся, что ключ 'value' есть
            if 'value' in joke_data:
                # вырежем текст шутки и покажем (можно обрезать для читаемости)
                joke_text = joke_data['value']
                # печатаем первые 80 символов, чтобы не захламлять консоль
                print(f'😂 Шутка: {joke_text[:80]}...' if len(joke_text) > 80 else f'😂 Шутка: {joke_text}')
            else:
                print('🤔 Странно, ключ "value" не найден. Возможно, сервер вернул ошибку.')
            jokes.append(joke_data)
        return jokes

# ---------- УРОК ПРИМЕНЕНИЯ ----------
if __name__ == '__main__':
    collector = ChuckNorrisJokeCollector()

    # Шаг 1 – получаем категории
    collector.fetch_categories()

    # Шаг 2 – собираем шутки методом params (способ №1)
    print('\n' + '='*50)
    print('🌟 СБОР ШУТОК МЕТОДОМ params')
    jokes_params = collector.collect_all_jokes(method='params')
    print(f'\n✅ Собрано шуток через params: {len(jokes_params)}')

    # Шаг 3 – собираем шутки методом ручной строки (способ №2)
    # Можно закомментировать, если нужно посмотреть только один способ.
    print('\n' + '='*50)
    print('🌟 СБОР ШУТОК МЕТОДОМ СТРОКИ')
    jokes_string = collector.collect_all_jokes(method='string')
    print(f'\n✅ Собрано шуток через строку: {len(jokes_string)}')
```

