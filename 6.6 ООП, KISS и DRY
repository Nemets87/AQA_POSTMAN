## 🎓 Улучшенный код с подробными комментариями (школьными подсказками)

```python
import requests
from typing import Dict, Any

class LocationAPI:
    """
    📘 Школьный класс "API-библиотека локаций".
    Хранит общую информацию (базовый URL, ключ доступа)
    и умеет отправлять запросы, соблюдая порядок и чистоту.
    """
    def __init__(self, base_url: str, key: str) -> None:
        """
        При создании объекта запоминаем:
        - base_url: адрес школы
        - key: ключ от входа в школу
        """
        self.base_url = base_url.rstrip('/')  # убираем возможный слеш в конце
        self.key = key

    def _build_url(self, resource: str, extra_params: str = "") -> str:
        """
        🧩 Собирает полный URL из:
        - resource: конкретный путь после базового адреса (напр. '/maps/api/place/add/json')
        - extra_params: дополнительные параметры (place_id и пр.)
        """
        url = f"{self.base_url}{resource}{self.key}"
        if extra_params:
            url += extra_params
        return url

    def _send_request(self, method: str, url: str, json_data: Dict[str, Any] = None) -> Dict[str, Any]:
        """
        📡 Главный почтальон школы.
        Получает:
        - method: 'post' или 'get'
        - url: полный адрес запроса
        - json_data: тело запроса для POST
        Возвращает распарсенный JSON-ответ, предварительно проверив статус-код.
        """
        print(f"📨 Отправляю {method.upper()}-запрос на {url}")
        if method.lower() == 'post':
            response = requests.post(url, json=json_data)
        elif method.lower() == 'get':
            response = requests.get(url)
        else:
            raise ValueError(f"Метод {method} не поддерживается — наша школа только для POST и GET!")

        # Проверка успешности — единая для всех запросов (DRY!)
        assert response.status_code == 200, (
            f"❌ Ошибка {method.upper()}: статус-код {response.status_code} вместо 200"
        )
        print(f"✅ {method.upper()} выполнен успешно (статус 200)")
        return response.json()

    def create_location(self, location_data: Dict[str, Any]) -> Dict[str, Any]:
        """
        🏗️ Создаёт новую локацию.
        Возвращает JSON-ответ, который обязательно содержит 'status' и 'place_id'.
        """
        post_resource = '/maps/api/place/add/json'
        url = self._build_url(post_resource)
        response_json = self._send_request('post', url, json_data=location_data)

        # Быстрая проверка важных полей (KISS: не переусложняем, но контролируем)
        assert response_json.get('status') == 'OK', "❌ Поле status не равно 'OK'"
        print("❤️ Поле status корректно (OK)")
        assert 'place_id' in response_json, "❌ В ответе отсутствует place_id"
        print(f"📍 Получен place_id: {response_json['place_id']}")
        return response_json

    def get_location(self, place_id: str) -> Dict[str, Any]:
        """
        🔍 Получает данные о локации по её идентификатору.
        Возвращает JSON с информацией.
        """
        get_resource = '/maps/api/place/get/json'
        extra = f"&place_id={place_id}"
        url = self._build_url(get_resource, extra)
        response_json = self._send_request('get', url)
        print("📖 Данные локации успешно получены")
        return response_json


# ═══════════════════ ДЕМОНСТРАЦИЯ (как день открытых дверей в школе) ═══════════════════
if __name__ == "__main__":
    print("\n🌟 День открытых дверей в школе 'LocationAPI' 🌟")
    print("=" * 50)

    # Создаём нашего библиотекаря (клиента API)
    api = LocationAPI(
        base_url='https://rahulshettyacademy.com',
        key='?key=qaclick123'
    )

    # Готовим данные для новой локации (как заявка на экскурсию)
    new_location = {
        "location": {
            "lat": -38.383494,
            "lng": 33.427362
        },
        "accuracy": 50,
        "name": "Frontline house",
        "phone_number": "(+91) 983 893 3937",
        "address": "29, side layout, cohen 09",
        "types": ["shoe park", "shop"],
        "website": "http://google.com",
        "language": "French-IN"
    }

    # Шаг 1: создаём локацию
    print("\n🏗️  Урок 1: Создание локации")
    post_response = api.create_location(new_location)
    print("✅ Локация успешно создана, ответ:", post_response)

    # Шаг 2: проверяем её существование через GET
    place_id = post_response['place_id']
    print("\n🔍 Урок 2: Получение информации о локации")
    get_response = api.get_location(place_id)
    print("✅ Информация получена, ответ:", get_response)

    print("\n🎉 Учебный день завершён! Всё прошло гладко благодаря ООП, DRY и KISS.")
```

