## 💻 Готовый код (с комментариями и фишками)

Ниже я **расширил** твой класс и добавил выполнение задания. Обрати внимание на новые моменты.

```python
import requests
from typing import Dict, Any, List

class LocationAPI:
    """📘 Школьный класс "API-библиотека локаций" (твой оригинал + мои комментарии)"""
    def __init__(self, base_url: str, key: str) -> None:
        self.base_url = base_url.rstrip('/')
        self.key = key

    def _build_url(self, resource: str, extra_params: str = "") -> str:
        url = f"{self.base_url}{resource}{self.key}"
        if extra_params:
            url += extra_params
        return url

    def _send_request(self, method: str, url: str, json_data: Dict[str, Any] = None) -> Dict[str, Any]:
        print(f"📨 Отправляю {method.upper()} на {url}")
        if method.lower() == 'post':
            response = requests.post(url, json=json_data)
        elif method.lower() == 'get':
            response = requests.get(url)
        else:
            raise ValueError(f"Метод {method} не поддерживается")
        
        # Фишка: проверяем не только 200, но и любые успешные 2xx (но тут API всегда 200)
        assert response.status_code == 200, f"❌ Ошибка {method.upper()}: статус {response.status_code}"
        print(f"✅ {method.upper()} успешен (статус 200)")
        return response.json()

    def create_location(self, location_data: Dict[str, Any]) -> Dict[str, Any]:
        post_resource = '/maps/api/place/add/json'
        url = self._build_url(post_resource)
        response_json = self._send_request('post', url, json_data=location_data)
        assert response_json.get('status') == 'OK', "❌ status не OK"
        assert 'place_id' in response_json, "❌ Нет place_id"
        print(f"📍 Создан place_id: {response_json['place_id']}")
        return response_json

    def get_location(self, place_id: str) -> Dict[str, Any]:
        get_resource = '/maps/api/place/get/json'
        extra = f"&place_id={place_id}"
        url = self._build_url(get_resource, extra)
        response_json = self._send_request('get', url)
        # Дополнительная проверка, что место действительно существует
        assert response_json.get('status') == 'OK', f"❌ place_id {place_id} не найден или ошибка"
        print(f"🔍 Место {place_id} существует, данные получены")
        return response_json


# ========== ВЫПОЛНЕНИЕ ЗАДАНИЯ (без портянки) ==========
def generate_location_variant(index: int) -> Dict[str, Any]:
    """
    🧠 Фишка: создаём разные локации, меняя name, address и координаты.
    Иначе API может вернуть ошибку "duplicate" или тот же place_id.
    """
    return {
        "location": {
            "lat": -38.383494 + index * 0.001,   # чуть смещаем координаты
            "lng": 33.427362 + index * 0.001
        },
        "accuracy": 50,
        "name": f"Frontline house #{index}",     # уникальное имя
        "phone_number": "(+91) 983 893 3937",
        "address": f"29, side layout, cohen {index:02d}", # уникальный адрес
        "types": ["shoe park", "shop"],
        "website": "http://google.com",
        "language": "French-IN"
    }

if __name__ == "__main__":
    print("\n🌟 НОВОЕ ЗАДАНИЕ: 5 мест → файл → проверка GET 🌟")
    print("=" * 60)

    # 1. Создаём клиента (как в прошлый раз)
    api = LocationAPI(
        base_url='https://rahulshettyacademy.com',
        key='?key=qaclick123'
    )

    # 2. Цикл для создания 5 локаций и сохранения place_id в список
    place_ids = []   # временный список, но по заданию потом будем читать из файла
    print("\n🏗️ Шаг 1: Создаём 5 локаций (POST)")
    for i in range(1, 6):   # красиво: range(1,6) даст 1..5
        print(f"\n--- Создаём локацию #{i} ---")
        location_data = generate_location_variant(i)
        response = api.create_location(location_data)
        place_ids.append(response['place_id'])

    # 3. Сохраняем ВСЕ 5 place_id в текстовый файл (по одному на строку)
    filename = "place_ids.txt"
    with open(filename, "w", encoding="utf-8") as file:
        for pid in place_ids:
            file.write(pid + "\n")
    print(f"\n💾 Файл '{filename}' создан, сохранено {len(place_ids)} place_id.")

    # 4. Читаем place_id из файла (НЕ используем старый список place_ids!)
    print(f"\n📂 Шаг 2: Читаем place_id из файла '{filename}'")
    ids_from_file = []
    with open(filename, "r", encoding="utf-8") as file:
        for line in file:
            clean_id = line.strip()
            if clean_id:          # пропускаем пустые строки
                ids_from_file.append(clean_id)
    print(f"Прочитано {len(ids_from_file)} идентификаторов: {ids_from_file}")

    # 5. Для каждого place_id из файла отправляем GET и проверяем существование
    print("\n🔍 Шаг 3: Проверяем каждый place_id через GET")
    all_exist = True
    for idx, pid in enumerate(ids_from_file, start=1):
        print(f"\n--- Проверка места #{idx} (place_id: {pid[:20]}...) ---")
        try:
            api.get_location(pid)
            print(f"✅ Место #{idx} существует")
        except AssertionError as e:
            print(f"❌ Ошибка: {e}")
            all_exist = False

    # Итог
    print("\n" + "=" * 60)
    if all_exist and len(ids_from_file) == 5:
        print("🎉 УСПЕХ! Все 5 place_id из файла существуют. Задание выполнено.")
    else:
        print("⚠️ Что-то пошло не так. Проверь вывод выше.")
```

