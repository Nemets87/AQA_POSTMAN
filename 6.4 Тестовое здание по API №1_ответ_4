python
import requests
from typing import List, Dict, Any

class ChuckJokesInteractive:
    """
    Класс для работы с API шуток Чака Норриса в интерактивном режиме.
    Позволяет пользователю выбрать категорию и получить шутку.
    """

    # Константы – URL endpoints (адреса, которые не меняются)
    CATEGORIES_URL = "https://api.chucknorris.io/jokes/categories"
    RANDOM_JOKE_URL = "https://api.chucknorris.io/jokes/random"

    def __init__(self) -> None:
        """При создании объекта загружаем список всех категорий и сохраняем."""
        self.categories: List[str] = self._fetch_categories()

    def _fetch_categories(self) -> List[str]:
        """
        Приватный метод: запрашивает список категорий у API.
        Возвращает список строк.
        """
        print("📡 Запрашиваю список всех категорий...")
        response = requests.get(self.CATEGORIES_URL)

        # Проверка статуса ответа – если не 200, программа остановится с ошибкой
        if response.status_code != 200:
            raise Exception(f"❌ Ошибка получения категорий! Код: {response.status_code}")

        categories = response.json()  # парсим JSON в список Python
        print(f"✅ Получено {len(categories)} категорий.")
        return categories

    def is_category_valid(self, category: str) -> bool:
        """
        Проверяет, существует ли указанная категория (регистронезависимо).
        Возвращает True, если категория есть в списке, иначе False.
        """
        # Приводим к нижнему регистру для безопасного сравнения
        return category.lower() in [cat.lower() for cat in self.categories]

    def get_joke_by_category(self, category: str) -> Dict[str, Any]:
        """
        Получает случайную шутку по указанной категории.
        Возвращает полный JSON-ответ (словарь).
        """
        print(f"🎯 Запрашиваю шутку для категории: {category}")
        # Используем params для чистой сборки URL (без склеивания строк)
        response = requests.get(self.RANDOM_JOKE_URL, params={"category": category})

        # Проверка статуса ответа
        if response.status_code != 200:
            raise Exception(f"❌ Ошибка получения шутки! Код: {response.status_code}")

        return response.json()

    def run_interactive(self) -> None:
        """
        Основной метод для интерактивного взаимодействия с пользователем.
        """
        print("\n🌟 Добро пожаловать в мир шуток Чака Норриса! 🌟")
        print("=" * 50)

        # Показываем список доступных категорий
        print(f"Доступные категории: {', '.join(self.categories)}")

        # Бесконечный цикл для повторного ввода, если категория не найдена
        while True:
            user_category = input("Введите категорию шутки (например, 'animal', 'dev', 'movie'): ").strip()

            # Если пользователь ничего не ввёл, просим снова
            if not user_category:
                print("⚠️ Вы не ввели категорию. Попробуйте ещё раз.")
                continue

            # Проверяем, существует ли введённая категория
            if not self.is_category_valid(user_category):
                print(f"❌ Категория '{user_category}' не найдена!")
                print(f"Доступные категории: {', '.join(self.categories)}")
                continue  # снова запрашиваем ввод

            # Если категория валидна, выходим из цикла
            break

        # Получаем шутку для выбранной категории
        try:
            joke_data = self.get_joke_by_category(user_category)
            joke_text = joke_data.get("value", "Шутка не найдена :(")
        except Exception as e:
            print(e)
            return

        # Выводим результат
        print("\n" + "=" * 50)
        print("😂 Ваша шутка Чака Норриса: 😂")
        print("-" * 50)
        print(joke_text)
        print("=" * 50)


# Точка входа в программу
if __name__ == "__main__":
    # Создаём объект-сборщик (автоматически загрузит категории)
    collector = ChuckJokesInteractive()
    # Запускаем интерактивный режим
    collector.run_interactive()
🧠 Объяснение по кирпичикам (для особенного ученика)
1. Импорты
python
import requests
from typing import List, Dict, Any
requests — библиотека для отправки HTTP-запросов (как курьер, который ходит к API).

typing — помогает нам указывать, какие типы данных ожидаются (например, List[str] означает «список строк»). Это как этикетки на коробках.

2. Класс ChuckJokesInteractive
Класс — это чертёж (шаблон) для создания объектов. В нашем случае объект будет уметь общаться с API Чака Норриса.

Константы (CATEGORIES_URL, RANDOM_JOKE_URL) — это адреса, которые не меняются. Их удобно вынести вверх, чтобы легко менять при необходимости.

3. Метод __init__ (конструктор)
Вызывается автоматически при создании объекта. Он сразу загружает список категорий и сохраняет его в self.categories.

4. Приватный метод _fetch_categories
Приватный (с нижним подчёркиванием) — значит, его не следует вызывать снаружи класса. Он для внутреннего использования.

Отправляет GET-запрос к CATEGORIES_URL.

Проверяет статус-код: если не 200, выбрасывает исключение (программа падает с ошибкой). Это хорошая практика: не стоит продолжать работу, если сервер не ответил.

Получает JSON-ответ, который преобразуется в список Python.

Возвращает этот список.

5. Метод is_category_valid
Проверяет, есть ли введённая категория в списке.

Приводит и ввод, и список к нижнему регистру, чтобы "Animal" и "animal" считались одинаковыми.

6. Метод get_joke_by_category
Отправляет GET-запрос к RANDOM_JOKE_URL, передавая параметр category через params (безопасно и чисто).

Проверяет статус-код.

Возвращает JSON-ответ в виде словаря Python.

7. Метод run_interactive
Содержит логику общения с пользователем.

Цикл while True: повторяет запрос категории, пока пользователь не введёт что-то корректное.

Если категория не найдена, выводит список доступных и продолжает цикл.

После получения корректной категории вызывает get_joke_by_category и печатает шутку.

8. Точка входа if __name__ == "__main__":
Этот блок выполняется только если файл запущен напрямую (а не импортирован как модуль).

Создаём объект класса и запускаем интерактивный режим.

🧼 Принципы KISS, DRY, OOP
KISS (Keep It Simple, Stupid): Мы не пишем сложных конструкций. Всё разбито на маленькие понятные методы. URL собирается через params, а не ручной склейкой.

DRY (Don't Repeat Yourself): Проверка статуса ответа вынесена в каждый метод отдельно (но это не дублирование, а разные проверки). Главное, что мы не копируем код для получения шутки — он в одном методе.

OOP (Object-Oriented Programming): Класс инкапсулирует данные (список категорий) и методы для работы с ними. Мы не смешиваем логику API и логику ввода-вывода.

