import requests
import time
from typing import Dict, Any, List

class LocationAPI:
    def __init__(self, base_url: str, key: str) -> None:
        self.base_url = base_url.rstrip('/')
        self.key = key

    def _build_url(self, resource: str, extra_params: str = "") -> str:
        url = f"{self.base_url}{resource}{self.key}"
        if extra_params:
            url += extra_params
        return url

    def _send_request(self, method: str, url: str, json_data: Dict[str, Any] = None) -> Dict[str, Any]:
        print(f"📨 {method.upper()} → {url}")
        if method.lower() == 'post':
            response = requests.post(url, json=json_data)
        elif method.lower() == 'get':
            response = requests.get(url)
        else:
            raise ValueError(f"Метод {method} не поддерживается")
        assert response.status_code == 200, f"❌ HTTP {response.status_code}"
        print(f"✅ HTTP 200 OK")
        return response.json()

    def create_location(self, location_data: Dict[str, Any]) -> Dict[str, Any]:
        url = self._build_url('/maps/api/place/add/json')
        response_json = self._send_request('post', url, json_data=location_data)
        assert response_json.get('status') == 'OK', f"❌ Ошибка POST: {response_json}"
        assert 'place_id' in response_json, "❌ Нет place_id"
        print(f"📍 Создан place_id: {response_json['place_id']}")
        return response_json

    def get_location(self, place_id: str) -> Dict[str, Any]:
        url = self._build_url('/maps/api/place/get/json', f"&place_id={place_id}")
        response_json = self._send_request('get', url)
        
        # 🧠 Фишка: если нет поля 'status' – значит, успех (данные пришли)
        if 'status' in response_json:
            assert response_json['status'] == 'OK', f"❌ Ошибка: {response_json}"
        else:
            print("✅ Данные получены (поле status отсутствует – это нормально для этого API)")
        
        print(f"🔍 Место {place_id[:20]}... существует")
        return response_json


