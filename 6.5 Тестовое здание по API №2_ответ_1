### 📝 Итоговый код с улучшениями

```python
import requests
from typing import List, Dict, Any

class ChuckJokesInteractive:
    """
    Класс для работы с API шуток Чака Норриса в интерактивном режиме.
    Позволяет пользователю выбрать категорию и получить шутку.
    """

    CATEGORIES_URL = "https://api.chucknorris.io/jokes/categories"
    RANDOM_JOKE_URL = "https://api.chucknorris.io/jokes/random"

    def __init__(self) -> None:
        """При создании объекта загружаем список всех категорий."""
        self.categories: List[str] = self._fetch_categories()

    def _fetch_categories(self) -> List[str]:
        """Запрашивает список категорий у API. Возвращает список строк."""
        print("📡 Запрашиваю список всех категорий...")
        response = requests.get(self.CATEGORIES_URL)
        # Используем assert для проверки статуса, так как без него дальнейшая работа невозможна
        assert response.status_code == 200, f"❌ Ошибка получения категорий! Код: {response.status_code}"
        categories = response.json()
        print(f"✅ Получено {len(categories)} категорий.")
        return categories

    def is_category_valid(self, category: str) -> bool:
        """Проверяет существование категории (регистронезависимо)."""
        return category.lower() in [cat.lower() for cat in self.categories]

    def get_joke_by_category(self, category: str) -> Dict[str, Any]:
        """Получает случайную шутку для указанной категории."""
        print(f"🎯 Запрашиваю шутку для категории: {category}")
        response = requests.get(self.RANDOM_JOKE_URL, params={"category": category})
        assert response.status_code == 200, f"❌ Ошибка получения шутки! Код: {response.status_code}"
        return response.json()

    def _get_valid_category(self) -> str:
        """Запрашивает категорию до получения корректного значения."""
        while True:
            user_category = input("Введите категорию шутки: ").strip().lower()
            if self.is_category_valid(user_category):
                return user_category
            print(f"❌ Категория '{user_category}' не найдена. Попробуйте снова.")
            print(f"Доступные категории: {', '.join(self.categories)}")

    def _print_separator(self, char: str = "=", length: int = 50) -> None:
        """Печатает разделительную линию."""
        print(char * length)

    def run_interactive(self) -> None:
        """Основной метод для интерактивного взаимодействия."""
        print("\n🌟 Добро пожаловать в мир шуток Чака Норриса! 🌟")
        self._print_separator()

        print(f"Доступные категории: {', '.join(self.categories)}")
        user_category = self._get_valid_category()

        joke_data = self.get_joke_by_category(user_category)
        joke_text = joke_data.get("value", "Шутка не найдена :(")

        self._print_separator()
        print("😂 Ваша шутка Чака Норриса: 😂")
        self._print_separator(char="-")
        print(joke_text)
        self._print_separator()


if __name__ == "__main__":
    collector = ChuckJokesInteractive()
    collector.run_interactive()
```

