## 🧱 Итоговый код (лаконичный, только params)

```python
import requests
from typing import List, Dict, Any

class ChuckJokes:
    """Класс-сборщик шуток Чака Норриса по всем категориям."""

    # Константы – адреса, которые не меняются (как названия глав в учебнике)
    CATEGORIES_URL = "https://api.chucknorris.io/jokes/categories"
    RANDOM_JOKE_URL = "https://api.chucknorris.io/jokes/random"

    def __init__(self) -> None:
        """При создании объекта сразу загружаем список категорий."""
        self.categories: List[str] = self._fetch_categories()

    def _fetch_categories(self) -> List[str]:
        """Получить список всех категорий. Нижнее подчёркивание говорит:
        'этот метод для внутреннего использования, не вызывай снаружи'."""
        print("📡 Запрашиваю список категорий...")
        response = requests.get(self.CATEGORIES_URL)
        # Строгая проверка – если не 200, урок останавливается
        assert response.status_code == 200, f"❌ Ошибка получения категорий! Код: {response.status_code}"
        categories = response.json()
        print(f"✅ Категорий получено: {len(categories)}")
        return categories

    def get_joke_by_category(self, category: str) -> Dict[str, Any]:
        """Получить одну случайную шутку по заданной категории.
        Используем params – библиотека сама соберёт URL."""
        print(f"🎯 Категория: {category}")
        # Вот она, магия params! Никакой склейки строк, только словарь.
        response = requests.get(self.RANDOM_JOKE_URL, params={"category": category})
        assert response.status_code == 200, f"❌ Ошибка шутки для '{category}'! Код: {response.status_code}"
        return response.json()

    def collect_all_jokes(self) -> List[Dict[str, Any]]:
        """Собрать по одной шутке на каждую категорию.
        Возвращает список словарей с полными данными."""
        jokes: List[Dict[str, Any]] = []
        print("\n🌟 Начинаю сбор шуток по всем категориям!\n")
        for idx, cat in enumerate(self.categories, start=1):
            print(f"--- Шутка {idx}/{len(self.categories)} ---")
            joke_data = self.get_joke_by_category(cat)
            jokes.append(joke_data)

            # Достаём текст шутки и печатаем его (кратко, чтобы не загромождать консоль)
            text: str = joke_data.get("value", "")
            # Показываем первые 75 символов
            short_text = (text[:75] + "...") if len(text) > 75 else text
            print(f"😂 {short_text}\n")
        return jokes


# 🏁 Точка входа – как звонок на урок
if __name__ == "__main__":
    collector = ChuckJokes()                  # Создаём сборщика (он уже знает все категории)
    all_jokes = collector.collect_all_jokes() # Запускаем сбор
    print("=" * 40)
    print(f"🏆 Итог: собрано шуток – {len(all_jokes)} (должно быть 16)")
```

