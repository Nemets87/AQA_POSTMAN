import requests 

class Test_new_location():
    """
    Работа с новой локацией
    """
    def test_create_new_location(self):

        """
        Создание новой локации POST_metod
        """
    print("✅POST_metod")

    base_url = 'https://rahulshettyacademy.com'    # базовая url
    key = '?key=qaclick123'                        # ключ допуска
    post_resourse = '/maps/api/place/add/json'     # путь метода post

    post_url = base_url + post_resourse + key
    print(post_url)

    """Создание новой локации"""

    json_new_location = {                          # тело запроса post
                "location": {
                    "lat": -38.383494,
                    "lng": 33.427362
                }, "accuracy": 50,
                "name": "Frontline house",
                "phone_number": "(+91) 983 893 3937",
                "address": "29, side layout, cohen 09",
                "types": [
                    "shoe park",
                    "shop"
                ],
                "website": "http://google.com",
                "language": "French-IN"
            }


    result_post = requests.post(post_url, json=json_new_location)     # отправка запроса post, который включает url и тело запроса
    print('✅result_post.json()')
    print(result_post.json())

    print(f'Статус-код📀: {result_post.status_code}')

    assert result_post.status_code == 200, 'ОШИБКА, Статус-код не совпадают'
    print('✅Статус-код корректен')

    print(f'Статус-код: {result_post.status_code}') 

    if result_post.status_code == 200:
        print("Успешно! Мы создали локацию")
    else:
        print("Провал!")
    print('Статус-код корректен')   # отправка запроса
    print(result_post.text) 

    print(f'Статус-код: {result_post.status_code}')
    assert result_post.status_code == 200, 'ОШИБКА, Статус-код не совпадают'
    print('✅Статус-код POST корректен')



    check_response_post = result_post.json()
    check_info_post = check_response_post.get("status")
    print("❤️Статус check_info_post")

    status = check_response_post.get("status")    # получение значения обязательного поля ответа
    print(status)
    print(check_response_post)
    assert status == 'OK', 'ОШИБКА, Поле Status некорректно'
    print('❤️Поле Status корректно')


    place_id = check_response_post.get("place_id")   
    print(f'Поле place_id: {place_id}')
    assert 'place_id' in check_response_post
    print("Поле place_id присутствует в теле ответа")
    print('\n' + '=='*50)


    """
    Проверка создания новой локации GET_metod
    """
    print("✅GET_metod")
    base_url = 'https://rahulshettyacademy.com'    # базовая url
    key = '?key=qaclick123'                        # ключ допуска
    get_resourse = '/maps/api/place/get/json'      # путь метода get


    get_url = base_url + get_resourse + key + "&place_id=" + place_id     # добавление в url идентификатора place_id
    print(get_url)
    print('\n' + '&'*150)
    result_get = requests.get(get_url)
    print(result_get.json())

    print(f'Статус-код📀: {result_get.status_code}')
    assert result_get.status_code == 200, 'ОШИБКА, Статус-код не совпадают'
    print('✅Статус-код GET корректен')
    if result_post.status_code == 200:
        print("Успешно! поверка создания новой локации прошла успешно")
    else:
        print("Провал!")




    
    """
    Проверка изменения новой локации PUT_metod
    """

    # https://rahulshettyacademy.com/maps/api/place/update/json?key=qaclick123

    print("✅PUT_metod")
    base_url = 'https://rahulshettyacademy.com'    # базовая url
    key = '?key=qaclick123'                        # ключ допуска
    put_resourse = '/maps/api/place/update/json'   # путь метода put
    


    put_url = base_url + put_resourse + key   
    print(put_url)

    print('\n' + '^'*150)
    result_put = requests.put(put_url)
    print(result_put.text)

    print(f'Статус-код📀: {result_put.status_code}')
    assert result_put.status_code == 200, 'ОШИБКА, Статус-код не совпадают'
    print('✅Статус-код PUT корректен')
    if result_put.status_code == 200:
        print("Успешно! поверка создания новой локации прошла успешно")
    else:
        print("Провал!")

    json_put_location = { 

        "place_id":place_id,

        "address":"100 Lenina street, RU", 

        "key":"qaclick123" 

    }

    result_put = requests.put(put_url, json=json_put_location) # отпрвака запроса put, который включает url и тело запроса
    print(result_put.text)
  


    print(f'Статус-код📀: {result_put.status_code}')
    assert result_put.status_code == 200, 'ОШИБКА, Статус-код не совпадают'
    print('✅Статус-код PUT корректен')
    if result_put.status_code == 200:
        print("Успешно! поверка создания новой локации прошла успешно")
    else:
        print("Провал!")
    
    check_put = result_put.json()
    check_info_put = check_put.get("msg")
    print(f'сообщение msg: {check_info_put}')
    assert check_info_put == "Address successfully updated", 'ОШИБКА, сообщения ответы не совпадают'


       
    """
    Проверка изменения новой локации 
    """

    result_get = requests.get(get_url)
    print(result_get.text)

    print(f'Статус-код📀: {result_get.status_code}')
    assert result_get.status_code == 200, 'ОШИБКА, Статус-код не совпадают'
    print('✅Статус-код GET корректен')
    if result_post.status_code == 200:
        print("Успешно! поверка изменения новой локации прошла успешно")
    else:
        print("Провал!")

    check_adress = result_get.json()
    check_info_adress = check_adress.get("address")
    print(f'сообщение msg: {check_info_adress}')
    assert check_info_adress == "100 Lenina street, RU", 'ОШИБКА, адрес не совпадает'



new_place = Test_new_location()
new_place.test_create_new_location()
